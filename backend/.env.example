# ==========================================
# CẤU HÌNH DATABASE & BẢO MẬT
# ==========================================
# Cấu hình Database PostgreSQL
# Nếu bạn dùng Docker Compose với cấu hình mặc định, URL sẽ là:
DATABASE_URL="postgresql://rag_user:rag_password@localhost:5432/rag_db"

# JWT Secret Key (Bắt buộc phải đổi thành chuỗi ngẫu nhiên khi đưa lên Production)
SECRET_KEY="supper_secret_key_change_me_in_production"

# ==========================================
# CẤU HÌNH API KEY (DÀNH CHO ONLINE MODELS)
# ==========================================
# Nếu bạn muốn dùng ChatGPT (OpenAI) hoặc Gemini (Google), hãy điền API key vào đây.
# Hệ thống sẽ ưu tiên dùng OpenAI, sau đó là Gemini.
# Nếu để trống cả 2, hệ thống sẽ tự động chạy Local Models qua Ollama.

OPENAI_API_KEY=
GEMINI_API_KEY=

# (Tùy chọn) Chọn cụ thể model bạn muốn dùng nếu có API key
# OPENAI_LLM_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# GEMINI_LLM_MODEL=gemini-1.5-flash
# GEMINI_EMBEDDING_MODEL=text-embedding-004

# ==========================================
# CẤU HÌNH LANGSMITH (DÀNH CHO DEBUG/TRACING Lanchain)
# ==========================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langchain_api_key_here"
LANGCHAIN_PROJECT="Pro RAG Chatbot"
