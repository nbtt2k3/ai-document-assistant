# AI Agent environment example
# Copy this file to .env when running ai-agent outside Docker.

# -----------------------------------------------------------------------------
# Runtime paths
# -----------------------------------------------------------------------------
# These defaults are suitable for local development. Docker uses /app paths.
STORAGE_DIR=storage
DATA_PATH=storage/uploads
VECTORSTORE_PATH=storage/chroma_db
DOCSTORE_PATH=storage/docstore
FLASHRANK_CACHE=models/reranker

# -----------------------------------------------------------------------------
# HTTP / CORS
# -----------------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://web-api:8000

# -----------------------------------------------------------------------------
# Local models via Ollama
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=bge-m3

# -----------------------------------------------------------------------------
# Online LLM providers
# Priority in code: GitHub -> OpenRouter -> xAI -> Groq -> OpenAI -> Gemini -> Ollama.
# Leave unused providers blank.
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
GITHUB_LLM_MODEL=gpt-4o

OPENROUTER_API_KEY=
OPENROUTER_LLM_MODEL=qwen/qwen3-coder:free

XAI_API_KEY=
XAI_LLM_MODEL=grok-beta

GROQ_API_KEY=
GROQ_LLM_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

LLAMA_CLOUD_API_KEY=
COHERE_API_KEY=

# -----------------------------------------------------------------------------
# RAG tuning
# -----------------------------------------------------------------------------
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RERANK_TOP_N=5
MAX_FILE_SIZE_MB=50

# -----------------------------------------------------------------------------
# LangSmith tracing
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT="AI Document Assistant"
