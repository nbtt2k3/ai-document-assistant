# ==========================================
# CẤU HÌNH API KEY (DÀNH CHO ONLINE MODELS)
# ==========================================
# Nếu bạn muốn dùng ChatGPT (OpenAI) hoặc Gemini (Google), hãy điền API key vào đây.
# Hệ thống sẽ ưu tiên dùng OpenAI, sau đó là Gemini.
# Nếu để trống cả 2, hệ thống sẽ tự động chạy Local Models qua Ollama.

OPENAI_API_KEY=
GEMINI_API_KEY=

# (Tùy chọn) Chọn cụ thể model bạn muốn dùng nếu có API key
# OPENAI_LLM_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# GEMINI_LLM_MODEL=gemini-2.5-flash
# GEMINI_EMBEDDING_MODEL=gemini-embedding-2

# ==========================================
# CẤU HÌNH OLLAMA (DÀNH CHO LOCAL MODELS)
# ==========================================
# URL của Ollama server. Mặc định dùng Docker internal host.
# Nếu chạy trực tiếp (không Docker), đổi thành http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ==========================================
# CẤU HÌNH LANGSMITH (DÀNH CHO DEBUG/TRACING Langchain)
# ==========================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY="your_langchain_api_key_here"
LANGCHAIN_PROJECT="AI Document Assistant"
